{
	"name": "code-allemansgeest",
	"private": true,
	"version": "0.0.1",
	"type": "module",
	"scripts": {
		"dev": "vite dev",
		"build": "vite build",
		"preview": "vite preview",
		"prepare": "svelte-kit sync || echo ''",
		"check": "svelte-kit sync && svelte-check --tsconfig ./tsconfig.json",
		"check:watch": "svelte-kit sync && svelte-check --tsconfig ./tsconfig.json --watch",
		"test": "vitest run",
		"db:generate": "drizzle-kit generate",
		"db:migrate:local": "wrangler d1 migrations apply allemansgeest-db --local",
		"db:migrate:remote": "wrangler d1 migrations apply allemansgeest-db --remote"
	},
	"devDependencies": {
		"@cloudflare/workers-types": "^5.20260723.1",
		"@sveltejs/adapter-cloudflare": "^7.2.9",
		"@sveltejs/kit": "^2.63.0",
		"@sveltejs/vite-plugin-svelte": "^7.1.2",
		"@vitest/ui": "^4.1.10",
		"drizzle-kit": "^0.31.10",
		"svelte": "^5.56.1",
		"svelte-check": "^4.6.0",
		"typescript": "^6.0.3",
		"vite": "^8.0.16",
		"vitest": "^4.1.10",
		"wrangler": "^4.113.0"
	},
	"dependencies": {
		"drizzle-orm": "^0.45.2"
	}
}
